@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-50">
    <!-- Header -->
    <header class="flex items-center justify-between p-4 bg-white border-b border-gray-200 shadow-sm">
        <button
            @onclick="OnReset"
            class="text-gray-600 text-sm px-3 py-1.5 rounded hover-lift-sm hover:bg-gray-100 transition-all duration-300">
            ← Back
        </button>
        <h1 class="font-bold text-gray-900 text-lg">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-gray-600 text-sm py-3 px-4 font-medium">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-amber-100 text-amber-800 text-center py-3 font-semibold text-sm border-b border-amber-200 animate-fade-in">
            🎉 BINGO! You got a line!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-6 animate-fade-in">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
