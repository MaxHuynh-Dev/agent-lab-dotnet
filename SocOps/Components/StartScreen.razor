<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gray-50">
    <div class="text-center max-w-sm animate-fade-in">
        <h1 class="text-5xl font-bold text-gray-900 mb-2">Soc Ops</h1>
        <p class="text-xl text-gray-600 mb-8 font-medium">Social Bingo</p>

        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-200 mb-8">
            <h2 class="font-semibold text-gray-900 mb-4 text-lg">How to play</h2>
            <ul class="text-left text-gray-600 text-sm space-y-3">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-accent text-white font-semibold py-3 px-8 rounded-lg text-lg hover-lift transition-all duration-300 shadow-sm hover:shadow-md">
            Start Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
