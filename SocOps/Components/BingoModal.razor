<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-xl p-8 max-w-xs w-full text-center shadow-lg animate-slide-up">
        <div class="text-6xl mb-4">🎉</div>
        <h2 class="text-4xl font-bold text-amber-500 mb-2">BINGO!</h2>
        <p class="text-gray-600 mb-8 text-lg">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-accent text-white font-semibold py-3 px-6 rounded-lg hover-lift transition-all duration-300 shadow-sm hover:shadow-md">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
